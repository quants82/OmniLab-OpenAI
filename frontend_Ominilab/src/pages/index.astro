---
import Layout from '../layouts/Layout.astro';

const experiments = [
  ['〰️', 'Harmonic Motion', 'BMI160 acceleration data and real-time motion analysis.', '/harmonic-motion-bmi160'],
  ['🌡️', 'Specific Heat Capacity', 'Measure the specific heat capacity of water from live temperature and power data.', '/specific-heat'],
  ['🧲', 'Electromagnetic Induction', 'Observe induced voltage as the magnetic flux changes.', '/induction'],
  ['⚡', 'Capacitor Charge & Discharge', 'Capture exponential voltage curves and estimate the time constant.', '/capacitor'],
  ['💡', 'Incandescent Lamp I-V', 'Measure the nonlinear current-voltage response of a filament lamp.', '/lamp-va'],
  ['〽️', 'Resistor I-V', 'Verify Ohm’s law using ESP32 voltage and current measurements.', '/resistor-va'],
];
---

<Layout title="Ominilab — AI-Powered Open Physics Sandbox">
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-700 via-indigo-800 to-violet-800 text-white">
    <div class="absolute inset-0 opacity-20 [background-image:radial-gradient(circle_at_20%_20%,white,transparent_28%),radial-gradient(circle_at_80%_70%,#67e8f9,transparent_25%)]"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-24 md:py-32">
      <div class="max-w-4xl">
        <span class="rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.2em]">OpenAI Build Week 2026</span>
        <h1 class="mt-7 text-5xl font-black leading-tight md:text-7xl">Real physics.<br/><span class="text-cyan-300">Open hardware. AI insight.</span></h1>
        <p class="mt-6 max-w-3xl text-xl leading-relaxed text-blue-100">Ominilab turns low-cost ESP32 kits into a globally accessible laboratory. Collect real measurements, inspect live charts, and ask GPT-5.6 to explain the experiment.</p>
        <div class="mt-9 flex flex-wrap gap-4">
          <a href="/experiments" class="rounded-xl bg-white px-6 py-3 font-black text-blue-800 shadow-xl hover:bg-blue-50">Explore six experiments</a>
          <a href="/nap-firmware" class="rounded-xl border border-white/30 bg-white/10 px-6 py-3 font-black text-white hover:bg-white/20">Flash an ESP32</a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-20">
    <div class="mb-10 max-w-3xl">
      <p class="text-xs font-black uppercase tracking-[0.2em] text-blue-600">Focused submission</p>
      <h2 class="mt-3 text-4xl font-black text-slate-900">Six experiments, one transparent workflow</h2>
      <p class="mt-4 text-lg text-slate-600">Sign in, flash the public MicroPython source, connect the kit, stream measurements, and analyze the result.</p>
    </div>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {experiments.map(([icon, title, description, url]) => (
        <a href={url} class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-blue-300 hover:shadow-xl">
          <div class="text-4xl">{icon}</div>
          <h3 class="mt-5 text-xl font-black text-slate-900 group-hover:text-blue-700">{title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>
          <div class="mt-5 text-sm font-black text-blue-600">Open experiment →</div>
        </a>
      ))}
    </div>
  </section>

  <section class="border-y border-slate-200 bg-white">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:grid-cols-3">
      <div><div class="text-3xl">📡</div><h3 class="mt-3 font-black">Live ESP32 data</h3><p class="mt-2 text-sm text-slate-600">A minimal FastAPI WebSocket relay connects every kit to its browser dashboard.</p></div>
      <div><div class="text-3xl">🔓</div><h3 class="mt-3 font-black">Open firmware</h3><p class="mt-2 text-sm text-slate-600">The six MicroPython programs and required drivers are visible, auditable, and flashable in the browser.</p></div>
      <div><div class="text-3xl">🤖</div><h3 class="mt-3 font-black">GPT-5.6 lab assistant</h3><p class="mt-2 text-sm text-slate-600">Experiment measurements become grounded questions, feedback, and physics explanations.</p></div>
    </div>
  </section>
</Layout>
