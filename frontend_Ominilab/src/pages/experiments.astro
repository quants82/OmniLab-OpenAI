---
import Layout from '../layouts/Layout.astro';

const experiments = [
  { icon:'〰️', title:'Harmonic Motion with BMI160', area:'Mechanics', href:'/harmonic-motion-bmi160/', description:'Measure acceleration, period, frequency, amplitude, velocity, and phase from a spring-mass oscillator.' },
  { icon:'🌡️', title:'Specific Heat Capacity of Water', area:'Thermal Physics', href:'/specific-heat/', description:'Stream temperature and electrical power to estimate the specific heat capacity from experimental data.' },
  { icon:'🧲', title:'Electromagnetic Induction', area:'Electromagnetism', href:'/induction/', description:'Visualize induced voltage and connect the waveform to changing magnetic flux.' },
  { icon:'⚡', title:'Capacitor Charge and Discharge', area:'Circuits', href:'/capacitor/', description:'Record charging and discharging curves, then determine the RC time constant.' },
  { icon:'💡', title:'Incandescent Lamp I-V Characteristic', area:'Electricity', href:'/lamp-va/', description:'Explore nonlinear resistance as the filament temperature changes.' },
  { icon:'〽️', title:'Resistor I-V Characteristic', area:'Electricity', href:'/resistor-va/', description:'Test Ohm’s law and estimate resistance from the slope of the I-V graph.' },
];
---

<Layout title="Experiments — Ominilab">
  <section class="bg-slate-950 text-white">
    <div class="mx-auto max-w-7xl px-4 py-16">
      <p class="text-xs font-black uppercase tracking-[0.2em] text-cyan-300">Open experiment catalog</p>
      <h1 class="mt-3 text-5xl font-black">Six focused physics labs</h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-300">Each lab uses public ESP32 firmware, real sensor data, and a browser-based dashboard inherited from the VatLi365 educational ecosystem.</p>
    </div>
  </section>
  <section class="mx-auto grid max-w-7xl gap-6 px-4 py-16 md:grid-cols-2 lg:grid-cols-3">
    {experiments.map(exp => (
      <a href={exp.href} class="rounded-3xl border border-slate-200 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-blue-300 hover:shadow-xl">
        <div class="flex items-center justify-between"><span class="text-4xl">{exp.icon}</span><span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-black uppercase text-blue-700">{exp.area}</span></div>
        <h2 class="mt-6 text-xl font-black text-slate-900">{exp.title}</h2>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">{exp.description}</p>
        <div class="mt-6 font-black text-blue-600">Launch lab →</div>
      </a>
    ))}
  </section>
</Layout>
