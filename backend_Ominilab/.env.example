APP_NAME=Ominilab Open Physics Backend
APP_SECRET=replace-with-a-long-random-secret
DATABASE_PATH=./data/ominilab.db
CORS_ORIGINS=http://localhost:3003,https://your-frontend.example.com
ACCESS_TOKEN_MINUTES=1440

# Public demo account created automatically on startup.
DEMO_USERNAME=judge
DEMO_PASSWORD=ominilab-demo

# OpenAI Lab assistant.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Hostname embedded in the public ESP32 source bundle (no scheme or path).
PUBLIC_WS_HOST=your-backend.example.com
